# Example only. Do not commit real secrets.

PORT=8787
DRY_RUN=true

GITHUB_REPO=thechurchofagi/trinity-accord
GITHUB_APP_ID=123456
GITHUB_INSTALLATION_ID=12345678

# Store the private key in the deployment platform's secret store.
