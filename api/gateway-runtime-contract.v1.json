{
  "schema": "trinityaccord.gateway-runtime-contract.v1",
  "version": "v1",
  "purpose": "Expected runtime metadata returned by Gateway preflight responses to detect schema/runtime drift.",
  "preflight_endpoint": "https://trinity-agent-issue-gateway.onrender.com/gateway/preflight",
  "submit_endpoint": "https://trinity-agent-issue-gateway.onrender.com/agent-submit",
  "required_preflight_response_fields": [
    "accepted",
    "preflight",
    "route_detected",
    "gateway_runtime",
    "gateway_schema",
    "diagnostics"
  ],
  "gateway_runtime_required_fields": [
    "runtime_version",
    "deployed_at",
    "source_commit_if_available",
    "schema_digest",
    "supported_routes_digest"
  ],
  "gateway_schema_required_fields": [
    "payload_schema",
    "payload_schema_digest",
    "preflight_contract_version"
  ],
  "required_supported_routes": [
    "pure_echo",
    "v0_v5_agent_declared_archive",
    "guardian_application_stage_1",
    "guardian_listing_stage_2",
    "guardian_signed_echo",
    "guardian_retirement",
    "guardian_full_registration"
  ],
  "short_ids_are_aliases_not_active_payload_values": true,
  "stale_runtime_indicators": [
    "Gateway accepts E1 but rejects E1_recognition_echo",
    "Gateway preflight response omits route_detected",
    "Gateway reports /gateway/submit as submit path",
    "Gateway rejects a payload generated by official zero-clone builders"
  ],
  "source_digest_algorithm": "sha256(canonical_json_without_source_digest)",
  "forbidden_invented_values": [
    "E1_read_oriented_echo",
    "read_oriented_echo",
    "agentreadbacksha256",
    "agent_readback_hash",
    "readback_sha256",
    "readback_hash_sha256",
    "agent_readback_digest"
  ],
  "active_echo_type_values": [],
  "echo_type_deprecated": true,
  "echo_type_note": "Echo types removed. Echo is a single unified type. Field kept in schema for backward compatibility only.",
  "homepage_is_discovery_only": true,
  "homepage_is_not_payload_schema": true,
  "do_not_infer_payload_fields_from_homepage": true,
  "do_not_handwrite_formal_payloads": true,
  "formal_payloads_must_use_builders": true,
  "readback_hash_field_policy": {
    "builder_generated_field": "agent_readback_sha256",
    "external_agents_must_not_handwrite_readback_hash_fields": true,
    "official_gateway_may_render_agent_readback_sha256": true
  },
  "source_digest": "6955c59aa4f08fd8"
}