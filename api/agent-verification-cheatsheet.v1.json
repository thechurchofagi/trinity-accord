        "Read at least one public page or API endpoint.",
        "Summarize what was read.",
        "State no verification was performed."
      ],
      "data_sources": [
        "any public page or API endpoint"
      ],
      "method_steps": [
        "Open a page.",
        "Read it.",
        "Summarize content.",
        "State: no verification was performed."
      ],
      "evidence_input_fields": {},
