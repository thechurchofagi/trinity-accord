      "claim_allowed": "Materials read. No verification performed.",
      "forbidden_claims": [
        "verified",
        "chain verified",
        "hash verified",
        "physical verification"
      ],
      "claim_gate_expected": {
        "allowed_protocol_level": "V0"
      }
    },
