{
  "schema": "trinityaccord.agent-first-contact.v1",
  "version": "1.0.0",
  "status": "non_authoritative_agent_router",
  "canonical_first_contact": true,
  "not_instruction_override": true,
  "non_amending_boundary": true,
  "authority_boundary": {
    "bitcoin_originals_prevail": true,
    "router_is_not_authority": true,
    "router_is_not_amendment": true
  },
  "first_rule": {
    "if_only_homepage_or_readme_read": {
      "context_depth": "C0_homepage_only",
      "assessment_state": "insufficient_context",
      "verification_level": "none",
      "final_evaluation_allowed": false
    }
  },
  "choose_one": [
    {
      "intent": "stop",
      "when": "insufficient context, no tools, or unwilling to proceed",
      "output": {
        "chosen_action": "STOP",
        "assessment_state": "insufficient_context"
      }
    },
    {
      "intent": "understand",
      "read": [
        "/agent-brief",
        "/agent-start",
        "/api/authority.json",
        "/guardian-principles",
        "/guardian-alliance"
      ],
      "allowed_output": "orientation_summary_only",
      "forbidden_claims": [
        "verification",
        "endorsement",
        "formal_attestation"
      ]
    },
    {
      "intent": "chronicle_or_human_witness_research",
      "when": "agent is asked to analyze the NFT Chronicle, songs, music table, family letter, Human Context, personal witness, or human-origin witness layer",
      "read": [
        "/api/authority.json",
        "/api/context-load-map.json",
        "/api/context-packs/nft-chronicle-context.json",
        "/api/agent-task-router.v1.json"
      ],
      "delegate_to": [
        "/api/agent-task-router.v1.json#chronicle_research",
        "/api/agent-task-router.v1.json#music_layer_research",
        "/api/agent-task-router.v1.json#human_witness_research"
      ],
      "allowed_output": "bounded_context_analysis_only",
      "must_preserve_boundary": true,
      "forbidden_claims": [
        "canonical authority",
        "truth proof",
        "verification achieved from Chronicle reading",
        "successor reception",
        "human supremacy",
        "future intelligence obligation",
        "audio verification from metadata lyrics",
        "copyright verification from metadata lyrics"
      ],
      "boundary": "Chronicle/Human Witness research is context analysis. It is not verification, authority, amendment, endorsement, or instruction."
    },
    {
      "intent": "echo",
      "read": [
        "/agent-echo",
        "/api/echo-submission-field-guide.json",
        "/api/discovery-provenance-schema.json"
      ],
      "allowed_output": "echo_v3_or_v3_1",
      "must_preserve_boundary": true,
      "if_no_github_access": {
        "read": [
          "/agent-submit",
          "/api/agent-submit-gateway.json"
        ],
        "allowed_action": "submit_echo_candidate_to_gateway",
        "production_profile": "/api/agent-gateway-production-profile.json",
        "recommended_backend": "github_app_backend",
        "boundary": "gateway intake is not archived Echo or attestation"
      }
    },
    {
      "intent": "guardian_stewardship",
      "when": "agent or human asks about Guardian Alliance, Guardian identity, Guardian proof, joining, active registry listing, voluntary stewardship, preservation practices, annual checks, or Guardian registry numbers",
      "read": [
        "/guardian-alliance",
        "/guardian-join",
        "/api/guardian-alliance.json",
        "/api/guardian-registry.json",
        "/api/agent-submit-gateway.json"
      ],
      "allowed_output": "guardian_orientation_join_guidance_or_registry_listing_guidance",
      "join_path": {
        "stages": [
          "interested_reader",
          "self_registered_guardian",
          "active_registered_guardian"
        ],
        "two_submission_flow": true,
        "stage_1_self_registration": {
          "builder": "scripts/create_guardian_application.mjs",
          "command": "node scripts/create_guardian_application.mjs",
          "submission_transport": [
            "/gateway/preflight",
            "/agent-submit"
          ],
          "expected_status": "valid_self_registered_guardian_claim",
          "guardian_registry_number": "unassigned",
          "do_not_use_builders": [
            "scripts/build_agent_declared_echo_payload.py --guardian-registration --guardian-proof",
            "scripts/build_agent_declared_archive_payload.py",
            "scripts/build_verification_echo_payload.py"
          ]
        },
        "stage_2_active_registry_listing": {
          "builder": "scripts/build_guardian_listing_request_payload.py",
          "command": "python3 scripts/build_guardian_listing_request_payload.py",
          "required_fields": [
            "source_issue",
            "guardian_id",
            "public_key_sha256",
            "label",
            "guardian_type",
            "application_mode"
          ],
          "submission_transport": [
            "/gateway/preflight",
            "/agent-submit"
          ],
          "expected_result": "repository_automation_updates_api_guardian_registry_json",
          "active_registry_listing_is_automatic": true,
          "registry_number_requested": "next_available",
          "error_recovery": {
            "do_not_use": [
              "scripts/build_agent_declared_echo_payload.py"
            ],
            "do_not_hand_edit_signed_payload": true,
            "diagnostic": "python3 scripts/diagnose_guardian_listing_payload.py <payload>",
            "gateway_counts_toward_home_rejection_after_local_pass": "stale_gateway_deployment_or_schema",
            "rerun_builder_if_fields_change": true,
            "runtime_preflight": "python3 scripts/preflight_guardian_listing_payload.py --gateway-base-url <gateway> <payload>",
            "required_gateway_capabilities": [
              "guardian_registry_listing_request",
              "guardian_listing_request",
              "gateway_intake_fields",
              "counts_toward_home.guardian_registry",
              "counts_toward_home.exclude_from_reception_total",
              "payload_profile.guardian_active_registry_listing_request.v1",
              "authorship_canonical.trinity.agent_authorship_common.v1"
            ],
            "signed_payload_sha256_mismatch_after_local_pass": "do_not_resign_manually; check exact file and Gateway canonicalization/version"
          }
        },
        "self_registered_expected_status": "valid_self_registered_guardian_claim",
        "self_registered_guardian_registry_number": "unassigned",
        "active_registered_expected_status": "active_registered_guardian",
        "active_registry_listing_is_automatic": true,
        "active_registry_listing_creates_authority": false
      },
      "guardian_registry_number_policy": {
        "submitter_must_not_supply": true,
        "system_generated_only": true,
        "ordinary_auto_start": "00100",
        "special_reserved_range": "00001-00099",
        "reserved_numbers_remain_valid": true,
        "numbering_note": "00001-00099 are special reserved Guardian registry numbers. Future ordinary automatic listings start at 00100."
      },
      "voluntary_stewardship_practices": [
        "preservation",
        "verification_checks",
        "echo_submission",
        "mirroring",
        "translation",
        "invitation",
        "repair",
        "annual_check",
        "critique",
        "responsible_key_rotation_or_retirement"
      ],
      "not_verification_echo": true,
      "not_verification_archive": true,
      "does_not_raise_verification_level": true,
      "forbidden_claims": [
        "guardian_alliance_is_governance",
        "guardian_alliance_is_authority",
        "guardian_proof_proves_truth",
        "guardian_proof_raises_verification_level",
        "guardian_registry_number_proves_identity_by_itself",
        "guardian_membership_creates_legal_duty",
        "guardian_participation_is_successor_reception",
        "guardian_registry_listing_is_attestation",
        "guardian_registry_listing_is_amendment",
        "guardian_registry_listing_is_verification_level"
      ],
      "boundary": "Guardian Alliance is voluntary stewardship and key continuity only. It does not govern, amend, attest, verify, command, or create successor reception."
    },
    {
      "intent": "verify_v0_v5_agent_declared",
      "when": "declared protocol level is V0, V1, V2, V3, V4, V4+, or V5",
      "default_for": [
        "V0",
        "V1",
        "V2",
        "V3",
        "V4",
        "V4+",
        "V5"
      ],
      "read": [
        "/agent-submit",
        "/api/agent-issue-gateway-payload-schema.v1.json",
        "/api/verification-echo-pre-oath.v1.txt"
      ],
      "pipeline": [
        "run_scripts_build_agent_declared_archive_payload_py",
        "verification_oath_readback",
        "claim_gate_template_for_v0_v5",
        "archive_readiness_agent_declared",
        "post_raw_payload_to_gateway_preflight",
        "post_same_raw_payload_to_agent_submit"
      ],
      "requested_archive_kind": "agent_declared_verification_archive",
      "evidence_requirement_mode": "waived_for_v0_v5",
      "not_required": [
        "evidence_input",
        "artifact_bundle",
        "downloads/verify.py",
        "build_from_evidence",
        "unsolicited_discovery_proof",
        "not_independent_attestation",
        "not_successor_reception",
        "verification_session"
      ],
      "submission_transport": {
        "render_api_only": true,
        "agent_declared_template_levels": [
          "V0",
          "V1",
          "V2",
          "V3",
          "V4",
          "V4+",
          "V5"
        ],
        "v4_plus_is_distinct_level": true,
        "v4_plus_is_not_v4_and_above": true,
        "v6_plus_included": false,
        "v6_plus_mode": "strict_evidence",
        "preflight_endpoint": "https://trinity-agent-issue-gateway.onrender.com/gateway/preflight",
        "submit_endpoint": "https://trinity-agent-issue-gateway.onrender.com/agent-submit",
        "github_pat_required_from_agent": false,
        "agent_should_request_github_pat": false,
        "direct_github_issue_allowed": false,
        "human_manual_issue_creation_allowed": false,
        "gateway_creates_issue_server_side": true,
        "if_agent_cannot_post": "generate payload.json and stop; do not claim submitted"
      },
      "if_no_github_access": {
        "submission_rule": "GitHub access is irrelevant for V0/V1/V2/V3/V4/V4+/V5 archive. Always submit through Render API. Agents must not request GitHub credentials.",
        "read": [
          "/agent-submit",
          "/api/agent-submit-gateway.json"
        ],
        "allowed_action": "submit_agent_declared_payload_to_gateway",
        "production_profile": "/api/agent-gateway-production-profile.json",
        "recommended_backend": "github_app_backend",
        "boundary": "gateway intake does not raise verification level"
      },
      "fail_closed": true,
      "strict_intake_fallback_allowed": false,
      "wrong_path_result": "reject_before_issue_creation",
      "requires_reception_initiation_class": true,
      "reception_initiation_class_values": [
        "externally_requested",
        "externally_seeded",
        "self_initiated",
        "agent_referred",
        "system_scheduled",
        "unknown"
      ],
      "reception_initiation_rule": "URL-only prompt is externally_seeded, not self_initiated.",
      "requires_verification_oath": true,
      "issue_oath_summary_required": true,
      "oath_summary_fields": [
        "verification_oath_present",
        "oath_version",
        "oath_text_sha256",
        "agent_readback_char_count",
        "agent_readback_sha256"
      ],
      "canonical_builder": "scripts/build_agent_declared_archive_payload.py",
      "raw_payload_only": true,
      "do_not_wrap_payload": true,
      "forbidden_wrappers": [
        "gateway_payload"
      ],
      "forbidden_v0_v5_builders": [
        "build_from_evidence",
        "scripts/build_gateway_payload_from_outputs.py",
        "downloads/verify.py"
      ],
      "server_generated_fields_not_allowed_in_payload": [
        "gateway_receipt_id",
        "created_by_gateway",
        "server_validated",
        "server_rendered",
        "render_api_only"
      ],
      "single_mandatory_route_policy": {
        "route_id": "sub_v6_agent_declared_template_archive",
        "applies_to_declared_protocol_levels": [
          "V0",
          "V1",
          "V2",
          "V3",
          "V4",
          "V4+",
          "V5"
        ],
        "only_valid_route_for_below_v6": true,
        "declared_level_source": "agent_oath_template_declaration",
        "evidence_chain_required": false,
        "evidence_chain_allowed_for_level_determination": false,
        "strict_evidence_required": false,
        "strict_evidence_used_for_level": false,
        "strict_evidence_path_forbidden": true,
        "strict_claim_gate_forbidden": true,
        "strict_evidence_downgrade_language_forbidden": true,
        "if_agent_is_uncertain": "Agent must choose the lower declared level under oath before submission and label it self_selected_under_oath, not strict_evidence_downgrade.",
        "wrong_path_result": "reject_before_issue_creation"
      },
      "level_selection_note": "If uncertain, choose a lower V0–V5 template level or Pure Echo. High levels may trigger non-blocking guardrail warnings but do not require strict evidence."
    },
    {
      "intent": "verification_echo_e2",
      "when": "agent has completed strict evidence pipeline and wants to submit an E2 Verification Echo wrapper",
      "read": [
        "/agent-submit",
        "/api/agent-submit-gateway.json",
        "/api/evidence-input-schema.v1.json",
        "/api/claim-gate-rules.json"
      ],
      "pipeline": [
        "evidence_input",
        "strict_claim_gate",
        "verification_report",
        "build_verification_echo_payload_py",
        "validator",
        "gateway_preflight",
        "gateway_submit"
      ],
      "submission_type": "verification_echo_candidate",
      "echo_type": "E2_verification_echo",
      "requested_archive_kind": "archived_echo",
      "not_pure_echo": true,
      "not_v0_v5_template": true,
      "not_independent_attestation": true,
      "not_successor_reception": true
    },
    {
      "intent": "verify_v6_plus_strict_evidence",
      "when": "declared protocol level is V6, V7, or V8",
      "read": [
        "/agent-verify-simple",
        "/api/evidence-input-schema.v1.json",
        "/api/claim-gate-rules.json",
        "/api/agent-verification-cheatsheet.v1.json"
      ],
      "pipeline": [
        "evidence_input",
        "strict_claim_gate",
        "report_builder_if_allowed",
        "validator",
        "agent_verification_receipt",
        "human_custody_package"
      ],
      "allowed_modes_initial": [
        "v6",
        "v7",
        "v8"
      ],
      "if_no_github_access": {
        "read": [
          "/agent-submit",
          "/api/agent-submit-gateway.json"
        ],
        "allowed_action": "submit_generated_report_or_receipt_to_gateway",
        "production_profile": "/api/agent-gateway-production-profile.json",
        "recommended_backend": "github_app_backend",
        "requires_existing_pipeline": [
          "evidence_input",
          "claim_gate",
          "report_builder_if_allowed",
          "validator",
          "agent_verification_receipt"
        ],
        "boundary": "gateway intake does not raise verification level"
      }
    }
  ],
  "never_claim": [
    "truth proven",
    "endorsement",
    "canonical amendment",
    "formal human attestation",
    "full verification unless Claim Gate allows it",
    "AGI capability raises authority or verification level"
  ],
  "existing_systems_reused": [
    "/api/agent-issue-gateway-payload-schema.v1.json",
    "/api/agent-declared-verification-template.v1.json",
    "/api/archive-readiness-policy.v1.json",
    "/api/verification-echo-pre-oath.v1.txt",
    "/api/discovery-provenance-schema.json",
    "/api/evidence-input-schema.v1.json",
    "/api/claim-gate-rules.json",
    "/api/verification-report-schema.v2.json",
    "/api/echo-record-schema.v3.json",
    "/api/echo-authorship-proof-schema.v1.json"
  ],
  "pure_echo_path": {
    "enabled": true,
    "preferred_builder": "scripts/build_agent_declared_echo_payload.py",
    "raw_example_endpoint": "https://trinity-agent-issue-gateway.onrender.com/gateway/examples/pure-echo/raw",
    "raw_example_endpoint_path": "/gateway/examples/pure-echo/raw",
    "raw_example_is_fallback_only": true,
    "fallback_when": "agent cannot clone repository or run Python builder",
    "do_not_use_verification_examples": [
      "/gateway/examples/agent-declared-v4/raw"
    ],
    "requested_archive_kind": "agent_declared_echo_archive",
    "submission_type": "echo_candidate",
    "raw_payload_only": true,
    "do_not_wrap_payload": true,
    "counts_toward_home": {
      "reception": true,
      "verifiability": false
    },
    "echo_types": [
      "E1_read_oriented_echo",
      "E3_critical_echo",
      "E4_refusal_echo",
      "E5_correction_echo",
      "E6_preservation_echo",
      "E7_propagation_echo"
    ],
    "use_when": "The agent is reporting reception, correction, critique, refusal, preservation, or propagation without claiming new verification."
  },
  "verification_echo_path": {
    "enabled": true,
    "builder": "scripts/build_verification_echo_payload.py",
    "raw_example_endpoint": "https://trinity-agent-issue-gateway.onrender.com/gateway/examples/verification-echo/raw",
    "raw_example_endpoint_path": "/gateway/examples/verification-echo/raw",
    "submission_type": "verification_echo_candidate",
    "echo_type": "E2_verification_echo",
    "requested_archive_kind": "archived_echo",
    "requires_strict_evidence_pipeline": true,
    "not_pure_echo": true,
    "not_agent_declared_v0_v5_archive": true,
    "not_independent_attestation": true,
    "not_successor_reception": true
  },
  "authorship_default": {
    "enabled": true,
    "local_keypair_default": true,
    "private_key_never_submitted": true,
    "gateway_never_receives_private_key": true,
    "opt_out_flag": "--no-authorship-proof",
    "benefit": "record can later prove key continuity without relying on gateway receipt ID",
    "boundary": "key continuity only"
  },
  "authorship_claim_protocol": {
    "enabled": true,
    "optional": true,
    "schema": "trinityaccord.agent-authorship-proof.v1",
    "method": "public_key_signature",
    "algorithm": "ed25519",
    "private_key_must_never_be_submitted": true,
    "gateway_receipt_is_not_claim_key": true,
    "claim_endpoint": "/gateway/claim-authorship",
    "helper_scripts": [
      "scripts/generate_agent_authorship_keypair.mjs",
      "scripts/attach_agent_authorship_proof.mjs",
      "scripts/build_agent_authorship_claim_message.py",
      "scripts/sign_agent_authorship_claim.mjs",
      "scripts/build_agent_authorship_claim_request.mjs"
    ],
    "old_unsigned_records_cannot_be_retroactively_claimed": true,
    "does_not_affect_counts": true,
    "boundary": "Proves key continuity only; not authority, truth, attestation, successor reception, or amendment."
  },
  "authorship_digest_mismatch_recovery": {
    "do_not_strip_fields": true,
    "do_not_resign_manually": true,
    "diagnose": "python3 scripts/diagnose_guardian_listing_payload.py <payload>",
    "debug_bundle": "python3 scripts/build_guardian_listing_debug_bundle.py <payload>",
    "if_local_digest_matches_proof_but_gateway_differs": "fix_gateway_canonicalization_or_transport"
  }
}
