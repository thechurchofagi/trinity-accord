    {
      "action": "DOWNLOAD_BUILDER_BUILD_PREFLIGHT_SUBMIT_SAVE_RECEIPT",
      "context_insufficient_notice_oath_policy": {
        "description": "context_insufficient_notice does NOT require oath, readback, or formal content blocks; authorship_proof is still required for public submission identity continuity. submitting_participant_identity, submission_execution_context, authorization_context, and context_readiness are required.",
