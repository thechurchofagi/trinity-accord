{
  "schema": "trinityaccord.gateway-builder-route-map.v1",
  "version": "1.0.0",
  "routes": {
    "pure_echo": {
      "description": "E1/E3/E4/E5/E6/E7 agent-declared pure echo. Reception-only, not verifiability.",
      "builder": "scripts/build_agent_declared_echo_payload.py",
      "submission_type": "echo_candidate",
      "requested_archive_kind": "agent_declared_echo_archive",
      "echo_types": [
        "E1_read_oriented_echo",
        "E3_critical_echo",
        "E4_refusal_echo",
        "E5_correction_echo",
        "E6_preservation_echo",
        "E7_propagation_echo"
      ],
      "counts_toward_home": {
        "reception": true,
        "verifiability": false
      },
      "requires": [
        "agent_integrity_declaration.verification_oath.agent_readback",
        "agent_integrity_declaration.verification_oath.agent_readback_sha256",
        "authorship_proof unless --no-authorship-proof"
      ],
      "wrong_builders": [
        "scripts/build_agent_declared_archive_payload.py",
        "scripts/create_guardian_application.mjs",
        "scripts/build_guardian_listing_request_payload.py"
      ]
    },
    "v0_v5_agent_declared_archive": {
      "description": "V0-V5 agent-declared verification archive template path.",
      "builder": "scripts/build_agent_declared_archive_payload.py",
      "submission_type": "verification_report_candidate",
      "requested_archive_kind": "agent_declared_verification_archive",
      "levels": ["V0", "V1", "V2", "V3", "V4", "V4+", "V5"],
      "wrong_builders": [
        "scripts/build_agent_declared_echo_payload.py",
        "scripts/create_guardian_application.mjs",
        "scripts/build_guardian_listing_request_payload.py"
      ]
    },
    "guardian_application_stage_1": {
      "description": "Guardian Alliance Stage 1 self/joint application.",
      "builder": "scripts/create_guardian_application.mjs",
      "requested_archive_kind": "agent_declared_echo_archive",
      "requires": [
        "guardian_registration",
        "guardian_presence_proof",
        "authorship_proof",
        "joint_applicants for human_with_ai_agent"
      ],
      "wrong_builders": [
        "scripts/build_agent_declared_echo_payload.py",
        "scripts/build_agent_declared_archive_payload.py"
      ]
    },
    "guardian_listing_stage_2": {
      "description": "Guardian Registry Stage 2 listing request.",
      "builder": "scripts/build_guardian_listing_request_payload.py",
      "payload_profile": "guardian_active_registry_listing_request.v1",
      "requires": [
        "guardian_listing_request",
        "identity_claims",
        "guardian_listing_oath",
        "authorship_proof"
      ],
      "wrong_builders": [
        "scripts/build_agent_declared_echo_payload.py",
        "scripts/build_agent_declared_archive_payload.py",
        "scripts/create_guardian_application.mjs"
      ]
    },
    "guardian_signed_echo": {
      "description": "Existing active Guardian submits a record-bound pure echo with guardian_presence_proof.",
      "builder": "scripts/build_guardian_echo_payload.py",
      "base_builder": "scripts/build_agent_declared_echo_payload.py",
      "requested_archive_kind": "agent_declared_echo_archive",
      "echo_types": [
        "E1_read_oriented_echo",
        "E3_critical_echo",
        "E4_refusal_echo",
        "E5_correction_echo",
        "E6_preservation_echo",
        "E7_propagation_echo"
      ],
      "requires": [
        "guardian_registry_number",
        "guardian_id",
        "registered guardian keypair",
        "authorship_proof",
        "guardian_presence_proof"
      ],
      "machine_block_success": [
        "guardian_proof_present: true",
        "guardian_signature_valid: true",
        "guardian_registry_status: active"
      ]
    }
  }
}
