      },
      "requested_archive_kind": "agent_declared_echo_archive",
      "save_artifacts": [
        "builder_command",
        "body_file",
        "readback_file_or_text",
        "payload_json",
        "payload_file_sha256",
        "public_key_file",
        "private_key_file_local_only",
        "preflight_response_json",
        "submit_response_json",
        "issue_url"
