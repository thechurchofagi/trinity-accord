{
  "action_semantics": {
    "copy_paste_examples": "/external-agent-copy-paste-examples/",
    "echo_reference": "/api/echo-types.json",
    "echo_schema": "/api/echo-record-schema.v3.1.json",
    "guardian_join": "/guardian-join/",
    "guardian_principles": "/guardian-principles/",
    "guardian_registry": "/api/guardian-registry.json",
    "rule": "Echo, verification, Guardian Stage 1, Guardian Stage 2, and Guardian-signed Echo are distinct actions and must not be conflated."
  },
  "artifact_custody_url": "/api/gateway-artifact-custody.v1.json",
  "canonical_human_url": "/gateway-workflows/",
  "context_governance": {
    "context_depth_declaration": "/api/context-depth-declaration.v1.json",
    "context_depth_levels": "/api/context-depth-levels.json",
    "context_readiness_levels": "/api/context-readiness-levels.json",
    "crl_to_context_depth_mapping": "/api/crl-to-context-depth-mapping.json",
    "mission_governance": "/api/mission-governance.v1.json"
  },
  "machine_origin": "/api/agent-start.v1.json",
  "origin": "/agent-start/",
  "post_submit_readback_contract": {
    "archive_ready_does_not_mean": [
      "archive commit completed",
      "public index regenerated",
      "GitHub Pages deployed"
    ],
    "archive_ready_means": "Gateway believes the issue is eligible for archive automation.",
    "issue_created_does_not_mean": [
      "archived",
      "indexed",
      "public_status_updated",
      "guardian_registry_updated",
      "verified",
      "deployed"
    ],
    "issue_created_means": "Gateway created a GitHub Issue intake record.",
    "must_not_claim": [
      "archived_from_issue_created_alone",
      "public_status_updated_without_public_status_readback",
      "verified_from_gateway_acceptance_alone",
      "active_guardian_from_stage_1_alone",
      "active_guardian_from_stage_2_submission_alone"
    ],
    "purpose": "Agents must not treat Gateway issue creation as archive/public-status completion.",
    "required": true,
    "required_after_submit": [
      "save_submit_response_json",
      "extract_issue_url",
      "extract_issue_number",
      "extract_gateway_receipt_id_if_present",
      "read_issue_url_if_tool_access_allows",
      "read_route_specific_public_status_targets",
      "report_archive_status_if_known",
      "report_public_status_readback_performed",
      "state_remaining_uncertainty",
      "do_not_imply_background_completion"
    ],
    "required_exit_fields": [
      "route_chosen",
      "builder_used",
      "payload_generated",
      "preflight_attempted",
      "preflight_result",
      "submission_attempted",
      "submission_result",
      "gateway_receipt_id_if_any",
      "github_issue_url_if_any",
      "archive_status_if_known",
      "public_status_readback_performed",
      "verification_state_by_this_agent",
      "remaining_uncertainty",
      "next_step_or_stop_reason"
    ]
  },
  "route_map_url": "/api/gateway-builder-route-map.v1.json",
  "schema": "trinityaccord.gateway-workflows.v1",
  "universal_rules": [
    "choose_route_first",
    "use_matching_builder",
    "do_not_handwrite_proof_fields",
    "do_not_patch_signed_json",
    "save_required_artifacts",
    "run_gateway_preflight",
    "submit_only_after_preflight_accepts"
  ],
  "version": "1.0.0",
  "workflows": {
    "e2_verification_echo": {
      "copyable_example": "/api/external-agent-operation-examples.v1.json#/examples/e2_verification_echo",
      "deprecated_for_new_submissions": true,
      "human_anchor": "/gateway-workflows/#workflow-e2-verification-echo",
      "legacy_compatibility_only": true,
      "not_pure_echo": true,
      "pipeline": "strict evidence wrapper",
      "post_submit_readback": {
        "archive_status_rule": "Do not claim E2 archived until issue/index/readback confirms.",
        "exit_report_required": true,
        "required_targets": [
          "submit_response.issue_url",
          "/api/echo-index.json",
          "/api/public-home-status.json"
        ],
        "use_global_contract": true
      },
      "replacement_routes": [
        "v0_v5_agent_declared_archive",
        "v6_plus_strict_evidence"
      ],
      "save_artifacts": [
        "claim_gate_output",
        "wrapper",
        "report",
        "payload_json",
        "preflight_response_json",
        "submit_response_json"
      ],
      "success_criteria": {
        "gateway": [
          "preflight accepted",
          "submit issue_created"
        ]
      },
      "zero_clone_builder_bundle": "/api/formal-builder-bundles.v1.json#/bundles/e2_verification_echo",
      "inputs": []
    },
    "guardian_application_stage_1": {
      "builder": "scripts/create_guardian_application.mjs",
