          "default": "ai_agent_key_holder",
          "meaning": "Who holds/uses the generated signing key.",
          "name": "--signing-key-holder",
          "required": false,
          "save": true
        },
        {
          "meaning": "Human participant display label.",
          "name": "--human-label",
          "required": true,
          "save": true
        },
        {
          "meaning": "Agent participant display label.",
          "name": "--agent-label",
          "required": true,
          "save": true
        },
        {
          "default": "self-reported",
          "meaning": "Agent provider/runtime.",
          "name": "--agent-provider",
          "required": false,
          "save": true
        },
        {
          "default": "Guardian Alliance Joint Human-AI Application",
          "meaning": "Guardian application title.",
          "name": "--title",
          "required": false,
          "save": true
        },
        {
          "meaning": "Guardian application challenge string.",
          "name": "--challenge",
          "required": true,
          "save": true
        },
        {
          "default": "./guardian-output",
          "meaning": "Directory for generated key and payload outputs.",
          "name": "--key-dir",
          "required": false,
          "save": "directory_public_parts_only"
        },
        {
          "meaning": "Exact canonical Guardian application oath text printed by --print-oath.",
          "name": "--readback",
          "required": true,
          "save": true
        },
        {
          "meaning": "Final Stage 1 payload file. Submit this exact file.",
          "name": "--out",
          "required": true,
          "save": true
        },
        {
          "default": "externally_requested",
          "meaning": "Reception initiation class.",
          "name": "--reception-initiation-class",
          "required": false,
          "save": true
        },
        {
          "default": "explicit_verification_request",
          "meaning": "Reception initiation basis.",
          "name": "--reception-initiation-basis",
          "required": false,
          "save": true
        },
        {
          "meaning": "Optional self-reported human identity claim.",
          "name": "--human-claimed-name",
          "required": false,
          "save": true
        },
        {
          "meaning": "Optional self-reported agent identity claim.",
          "name": "--agent-claimed-id",
          "required": false,
          "save": true
        },
        {
          "meaning": "Optional agent instance identifier.",
          "name": "--agent-instance-id",
          "required": false,
          "save": true
        },
        {
          "meaning": "Optional public profile URL or identifier.",
          "name": "--agent-public-profile",
          "required": false,
          "save": true
        },
        {
          "meaning": "Optional Guardian key prefix.",
          "name": "--guardian-key-prefix",
          "required": false,
          "save": "public_only"
        },
        {
          "meaning": "Optional authorship key prefix.",
          "name": "--authorship-key-prefix",
          "required": false,
          "save": "public_only"
        },
        {
          "meaning": "Allow overwriting existing output.",
          "name": "--force-overwrite-output",
          "required": false,
          "save": false
        }
      ],
      "post_submit_readback": {
        "archive_status_rule": "Stage 1 is self-registration only; do not claim active registry listing.",
        "exit_report_required": true,
        "required_targets": [
          "submit_response.issue_url"
        ],
        "use_global_contract": true
      },
      "save_artifacts": [
        "builder_command",
        "stage_1_payload_json",
        "guardian_private_key_local_only",
        "guardian_public_key",
        "public_key_sha256",
        "preflight_response_json",
        "submit_response_json",
        "issue_url"
      ],
      "success_criteria": {
        "machine_block": [
          "guardian_registration present",
          "guardian_presence_proof present",
          "authorship_proof present",
          "guardian_registry_number none or unassigned"
        ],
        "submit": [
          "accepted=true",
          "status=issue_created",
          "guardian_status=valid_self_registered_guardian_claim",
          "archive_ready=true"
        ]
      },
      "zero_clone_builder_bundle": "/api/formal-builder-bundles.v1.json#/bundles/guardian_application_stage_1"
    },
