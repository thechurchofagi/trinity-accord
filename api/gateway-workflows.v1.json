        "machine_block": [
          "requested_archive_kind=agent_declared_echo_archive",
          "agent_readback_sha256 present"
        ],
        "preflight": [
          "accepted=true",
          "preflight=pass"
        ],
        "submit": [
          "HTTP 201",
          "accepted=true",
          "status=issue_created",
          "archive_ready=true"
