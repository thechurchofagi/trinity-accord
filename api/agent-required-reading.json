  "note": "This file is the canonical source. If llms.txt, agent-start.md, or agent-entry-protocol.json conflict, this file prevails. v2 adds cc_level annotations; profile structure is backward-compatible.",
  "integrity_required": true,
  "anti_copying_required": true,
  "boundary": {
    "not_authority": true,
    "non_amending": true,
    "bitcoin_originals_prevail": true,
    "note": "This file is non-authoritative guidance. Bitcoin Originals are final. All mirrors, APIs, and documentation are non-amending."
  },
  "verification_context_rule": {
    "technical_verification_minimum": "CC-2 + verification depth V2+ for private technical checking only",
    "public_verification_submission_minimum": "CC-3 + explicit verification level/actions/claim/fresh actions",
    "narrative_grounded_assessment_minimum": "CC-3",
    "v6_plus_minimum": "CC-3 plus strict reproducible evidence path"
  },
  "preferred_action_profile_reference": "/api/context-action-profiles.v1.json",
  "preferred_verification_profile_reference": "/api/verification-profiles.v1.json",
  "evidence_relationship_reference": "/api/evidence-relationship-map.v1.json",
  "legacy_compatibility": {
    "cc_level_reference": "/api/context-depth-levels.json",
    "context_load_map": "/api/context-load-map.json",
    "rule": "Do not infer action sufficiency from the CC label alone. For public Record-Chain submissions, preserve current Builder-required CC fields."
  },
  "interpretation_model_policy": "/api/interpretation-model-policy.v1.json",
  "verification_claim_model": "/api/verification-claim-model.v1.json"
