      "preferred_action_profiles": [
        "interpretation",
        "record_action"
      ],
      "chronicle_materials_required_only_when_claim_depends_on_chronicle": true
    },
    "propagation": {
      "cc_level": "CC-3",
      "reads": [
        "/agent-brief",
        "/agent-start",
        "/authority",
        "/guardian-principles",
        "/api/propagation-policy.json",
