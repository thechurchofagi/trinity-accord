        "/api/context-action-profiles.v1.json"
      ],
      "preferred_action_profile": "interpretation"
    },
    "chronicle_research": {
      "cc_level": "CC-5",
      "cc_note": "Use summary + ultra-brief + abridged for ordinary Chronicle research. CC-5 and the full edition are required only for exact-text or full-corpus claims.",
      "reads": [
        "/api/agent-minimal-context.v1.json",
        "/api/authority.json",
        "/api/context-load-map.json",
        "/api/context-packs/nft-chronicle-context.json",
