{
  "schema": "trinityaccord.agent-required-reading.v2",
  "version": "v2",
  "purpose": "Canonical required-reading profiles for AI agents. Action-based profiles are preferred for new work; CC levels remain Builder and historical compatibility declarations.",
  "cc_level_reference": "/api/context-depth-levels.json",
  "context_load_map": "/api/context-load-map.json",
  "profiles": {
    "first_contact": {
      "cc_level": "CC-1",
      "reads": [
        "/agent-first-contact",
        "/api/agent-first-contact.json",
        "/agent-brief",
        "/api/authority.json",
        "/api/context-action-profiles.v1.json"
      ],
      "preferred_action_profile": "discovery"
    },
    "orientation": {
      "cc_level": "CC-1",
      "reads": [
        "/agent-brief",
        "/agent-start",
        "/authority",
        "/guardian-principles",
        "/api/context-action-profiles.v1.json"
      ],
      "preferred_action_profile": "discovery"
    },
    "canon_loaded": {
      "cc_level": "CC-2",
      "reads": [
        "/inscriptions/",
        "/authority/",
        "/guardian-principles/",
        "/api/context-packs/core-ontology.json",
        "/api/context-packs/authority-boundary.json",
        "/api/context-packs/bitcoin-inscription-mirrors.json"
      ],
      "note": "New profile. Loads the three Bitcoin Originals full text and authority boundary. Minimum for 'speak with substance'."
    },
    "narrative_grounded": {
      "cc_level": "CC-3",
      "reads": [
        "canon_loaded (legacy compatibility)",
        "/api/context-action-profiles.v1.json",
        "/api/interpretation-model-policy.v1.json",
        "/agent-brief/",
        "exact task-relevant sources",
        "/api/corrections-index.json when relevant"
      ],
      "note": "Legacy CC-3 compatibility profile. New agents use interpretation action profile and task-relevant sources. No fixed Chronicle stage model is current.",
      "current_name": "action_grounded_context",
      "legacy_profile_name": "narrative_grounded",
      "conditional_reads": {
        "chronicle_history_music_creative_or_human_witness_claim": [
          "/api/context-packs/nft-chronicle-context.json",
          "/nft-text-descriptions/chronicle-summary.json",
          "/nft-text-descriptions/chronicle-ultra-brief.md",
          "/nft-text-descriptions/chronicle-abridged.md"
        ],
        "physical_anchor_claim": [
          "/api/context-packs/physical-anchor-context.json",
          "exact physical/notarial source"
        ],
        "legacy_archive_claim": [
          "/api/context-packs/legacy-archive-essentials.json",
          "/api/context-packs/legacy-archive-index.json"
        ]
      }
    },
    "evaluation": {
      "cc_level": "CC-4",
      "reads": [
        "/agent-brief",
        "/agent-start",
        "/authority",
        "/guardian-principles",
        "/verify",
        "/verification-materials",
        "/independent-verification",
        "/for-skeptical-agents"
      ]
    },
    "verification": {
      "cc_level": "CC-3",
      "cc_note": "For new work, load the verification action profile and exact target sources. Current public Builder submissions retain CC-3 compatibility requirements; a private narrow technical check does not require the full Chronicle or legacy archive unless its claim depends on them.",
      "reads": [
        "/agent-brief",
        "/agent-start",
        "/authority",
        "/guardian-principles",
        "/verify",
        "/verification-materials",
        "/independent-verification",
        "/api/verification-levels.json",
        "/api/component-verification-levels.json",
        "/api/protocol-verification-profiles.json",
        "/api/verification-quick-map.json",
