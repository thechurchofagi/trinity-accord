      "preferred_action_profile": "verification"
    },
    "echo_submission": {
      "cc_level": "CC-3",
      "cc_note": "Current public Builder compatibility uses CC-3, but sufficiency comes from interpretation + record_action profiles and actual task-relevant sources. Chronicle is conditional, not universal.",
