{
  "schema": "trinityaccord.context-load-map.v1",
  "purpose": "Tell agents which context to load, index, defer, or load only for specific tasks.",
  "must_load_summary": [
    "/api/context-packs/core-ontology.json",
    "/api/context-packs/authority-boundary.json",
    "/api/context-packs/vision-layer.json",
    "/api/context-packs/physical-anchor-context.json",
    "/api/context-packs/bitcoin-inscription-mirrors.json",
    "/api/verification-echo-agent-playbook.json"
  ],
  "read_index_not_full_load": [
    "/api/context-packs/legacy-archive-index.json",
    "/api/context-packs/nft-chronicle-context.json",
    "/nft-text-descriptions/chronicle-summary.json",
    "/nft-text-descriptions/chronicle-agent-context.md",
    "/nft-text-descriptions/CHRONICLE-MUSIC-TABLE.md"
  ],
  "deferred": [],
  "task_specific_full_load": [
    "/nft-text-descriptions/chronicle-index.json",
    "/nft-text-descriptions/chronicle-full.md"
  ],
  "task_specific": [
    "/api/bitcoin-inscription-mirror-index.json",
    "/api/bitcoin-inscription-mirror-schema.v1.json",
    "/api/verification-levels.json",
    "/api/component-verification-levels.json",
