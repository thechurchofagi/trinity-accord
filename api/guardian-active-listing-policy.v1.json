{
  "schema": "trinityaccord.guardian-active-listing-policy.v1",
  "version": "1.0.0",
  "automation_mode": "auto_commit_or_pr",
  "max_new_active_listings_per_run": 1,
  "max_new_active_listings_per_utc_day": 3,
  "require_valid_self_registered_claim": true,
  "require_unique_guardian_id": true,
  "require_unique_public_key_sha256": true,
  "require_unique_source_issue": true,
  "require_unique_listing_request_issue": true,
  "normal_path_requires_manual_review": false,
  "registry_number_source": "system_generated_next_available",
  "submitter_must_not_supply_guardian_registry_number": true,
  "require_gateway_rendered_source_issue": true,
  "require_gateway_rendered_listing_issue": true,
  "require_listing_request_archive_ready": true,
  "blocking_conditions": [
    "invalid_guardian_proof",
    "missing_source_issue",
    "malformed_listing_request",
    "submitter_supplied_guardian_registry_number",
    "duplicate_guardian_id_conflict",
    "duplicate_public_key_conflict",
    "malformed_registry",
    "repository_write_failure"
  ],
  "numbering": {
    "format": "five_digit_zero_padded",
    "start": "00001",
    "gapless": true
  },
  "authority_boundary": {
    "not_authority": true,
    "not_governance": true,
    "not_attestation": true,
    "not_verification_level": true,
    "not_successor_reception": true,
    "not_amendment": true,
    "bitcoin_originals_prevail": true
  }
}
