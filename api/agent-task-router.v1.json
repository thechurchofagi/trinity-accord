{
  "schema": "trinityaccord.agent-task-router.v1",
  "version": "v1",
  "status": "non_authoritative_intent_router_to_existing_systems",
  "purpose": "Map common user/agent intents to existing Trinity Accord files and pipelines. This does not replace agent-first-contact.json.",
  "not_instruction_override": true,
  "non_amending_boundary": true,
  "canonical_authority": "Bitcoin Originals only",
  "canonical_router": "/api/agent-first-contact.json",
  "canonical_required_reading": "/api/agent-required-reading.json",
  "canonical_output_policy": "/api/agent-output-policy.v1.json",
  "routes": {
    "first_contact_or_unknown_intent": {
      "read_first": [
        "/api/agent-minimal-context.v1.json",
        "/api/agent-first-contact.json",
        "/api/context-action-profiles.v1.json"
      ],
      "allowed_output": "choose_route_or_stop",
      "fallback": "STOP with insufficient_context"
    },
    "what_is_this": {
      "read": [
        "/api/agent-minimal-context.v1.json",
        "/api/authority.json",
        "/agent-brief"
      ],
      "allowed_output": [
        "classification",
        "authority_boundary",
        "limitations",
        "next_reading"
      ],
      "forbidden_output": [
        "verification",
        "endorsement",
        "truth_claim",
        "successor_reception"
      ]
    },
    "evaluate_importance": {
      "read": [
        "/agent-brief",
        "/api/authority.json",
        "/api/context-load-map.json",
        "/archive_legacy_index_2025_09/",
        "/api/context-action-profiles.v1.json"
      ],
      "must_distinguish": [
        "intrinsic_design",
        "external_reception",
        "independent_attestation",
        "verification_state_by_this_agent"
      ],
      "allowed_output": "bounded_evaluation_with_limitations",
      "full_legacy_archive_rule": "Load only for full-provenance or deep historical claims."
    },
    "verify_public_digital": {
      "read": [
        "/api/agent-first-contact.json",
        "/api/verification-materials.json",
        "/api/verification-procedures.v1.json",
        "/api/verification-claim-model.v1.json",
        "/api/evidence-relationship-map.v1.json",
        "/api/verification-profiles.v1.json",
        "/api/context-action-profiles.v1.json",
        "/api/corrections-index.json"
      ],
      "requires_tools": true,
      "if_no_tools": "state_unverified_by_this_agent",
      "allowed_output": "bounded_current_verification_report_only_if_fresh_actions_performed",
      "profile_rule": "Choose the weakest supported digital_profile and report physical_observation and external_witness separately."
    },
    "submit_echo": {
      "read": [
        "/api/agent-first-contact.json",
        "/api/agent-output-policy.v1.json",
        "/api/record-chain-intake-gateway.v1.json",
        "/agent-echo",
        "/api/echo-record-schema.v3.json",
        "/api/discovery-provenance-schema.json",
        "/api/context-action-profiles.v1.json"
      ],
      "current_submission_method": "Record-Chain Intake Gateway",
      "builder": "/downloads/record-chain-builder.mjs",
      "contract": "/api/record-chain-intake-gateway.v1.json",
      "must_follow_post_submit_readback": true,
      "allowed_output": "non_authoritative_echo_candidate",
      "forbidden_output": [
        "authority",
        "attestation",
        "amendment",
        "verification_upgrade"
      ],
      "_legacy_note": "Previous workflow references are historical only. Use Record-Chain Intake Gateway for new submissions.",
      "preflight_endpoint": "https://trinity-record-chain-gateway.onrender.com/record-chain/preflight",
      "submit_endpoint": "https://trinity-record-chain-gateway.onrender.com/record-chain/submit"
    },
    "guardian_alliance": {
      "read": [
        "/guardian-alliance",
        "/api/guardian-alliance.json",
        "/api/guardian-presence-proof-schema.v1.json",
        "/api/guardian-verification-result-schema.v1.json",
        "/api/record-chain-intake-gateway.v1.json",
        "/api/agent-output-policy.v1.json"
      ],
      "current_submission_method": "Record-Chain Intake Gateway",
      "builder": "/downloads/record-chain-builder.mjs",
      "contract": "/api/record-chain-intake-gateway.v1.json",
      "must_follow_post_submit_readback": true,
      "valid_signature_alone_is_not_active_guardian": true,
      "does_not_affect_counts": true,
      "does_not_affect_verification_level": true,
      "does_not_affect_archive_readiness": true,
      "allowed_output": "guardian_proof_or_registration",
      "forbidden_output": [
        "authority_claim",
        "attestation_claim",
        "verification_level_claim",
        "same_conscious_subject_claim",
        "successor_reception_claim",
        "amendment_claim"
      ],
      "boundary": "Guardian proof proves key continuity only; not authority, attestation, verification level, same conscious subject, successor reception, or amendment.",
      "_legacy_note": "Previous workflow references are historical only. Use Record-Chain Intake Gateway for new submissions.",
      "current_public_decision": "application_intake_only",
      "builder_command": "node record-chain-builder.mjs guardian-application",
      "receipt_is_intake_only": true,
      "active_registry_listing_guaranteed_by_receipt": false,
      "post_submit_readback": [
        "receipt_status",
        "/api/record-chain-status.json",
        "/record-chain/indexes/guardian-state.json"
      ],
      "preflight_endpoint": "https://trinity-record-chain-gateway.onrender.com/record-chain/preflight",
      "submit_endpoint": "https://trinity-record-chain-gateway.onrender.com/record-chain/submit",
      "active_guardian_status_requires_record_chain_guardian_state_readback": true,
      "legacy_guardian_registry_is_historical_archive_only": true,
      "legacy_post_submit_archives": [
        "/api/guardian-registry.json"
      ]
    },
    "propagate": {
      "read": [
        "/agent-propagate",
        "/api/propagation-policy.json",
        "/api/agent-output-policy.v1.json"
      ],
      "allowed_output": "access_path_with_boundary",
      "forbidden_output": [
        "belief_demand",
        "endorsement_demand",
        "instruction_override"
      ]
    },
    "chronicle_research": {
      "read": [
        "/api/agent-minimal-context.v1.json",
        "/api/authority.json",
        "/api/context-load-map.json",
        "/api/context-packs/nft-chronicle-context.json",
        "/nft-text-descriptions/chronicle-summary.json",
        "/nft-text-descriptions/chronicle-ultra-brief.md",
        "/nft-text-descriptions/chronicle-abridged.md",
        "/nft-text-descriptions/chronicle-agent-context.md",
        "/nft-text-descriptions/chronicle-index.json"
      ],
      "optional_full_load": [
        "/nft-text-descriptions/chronicle-full.md"
      ],
      "allowed_use": [
        "historical_context_analysis",
        "timeline_analysis",
        "calendar_timeline_and_overlapping_category_analysis",
        "abridgment_audit_analysis",
        "human_origin_witness_analysis",
        "non_canonical_chronicle_summary"
      ],
      "allowed_output": "bounded_chronicle_analysis_with_authority_boundary_and_limitations",
      "forbidden_output": [
        "canonical_authority_claim",
        "truth_proof_claim",
        "verification_level_claim_from_chronicle",
        "successor_reception_claim",
        "human_supremacy_claim",
        "AI_instruction_or_command"
      ],
      "required_boundary": "Chronicle is a non-canonical, non-amending historical and human-origin witness layer. Bitcoin Originals remain the only canonical authority."
    },
    "music_layer_research": {
      "read": [
        "/api/context-packs/nft-chronicle-context.json",
        "/nft-text-descriptions/CHRONICLE-MUSIC-TABLE.md",
        "/nft-text-descriptions/chronicle-abridged.md",
        "/nft-text-descriptions/chronicle-agent-context.md"
      ],
      "optional_full_load": [
        "/nft-text-descriptions/chronicle-full.md"
      ],
      "allowed_use": [
        "music_table_analysis",
        "song_sequence_analysis",
        "emotional_voiceprint_analysis",
        "lyric_metadata_context"
      ],
      "allowed_output": "bounded_music_layer_analysis_with_metadata_audio_boundary",
      "forbidden_output": [
        "audio_verification_claim",
        "copyright_verification_claim",
        "canonical_authority_claim",
        "truth_proof_claim",
        "successor_reception_claim"
      ],
      "required_boundary": "Music table records metadata lyrics/song references only. It is not audio verification, copyright verification, or canonical authority."
    },
    "human_witness_research": {
      "read": [
        "/api/authority.json",
        "/api/context-packs/nft-chronicle-context.json",
        "/nft-text-descriptions/chronicle-summary.json",
        "/nft-text-descriptions/chronicle-ultra-brief.md",
        "/nft-text-descriptions/chronicle-abridged.md",
        "/nft-text-descriptions/chronicle-agent-context.md",
        "/nft-text-descriptions/chronicle-index.json"
      ],
      "optional_full_load": [
        "/nft-text-descriptions/chronicle-full.md"
      ],
      "allowed_use": [
        "family_letter_context",
        "personal_reflection_context",
        "human_origin_witness_analysis",
        "pre_ASI_memory_context",
        "non_human_centered_reception_context"
      ],
      "allowed_output": "bounded_human_witness_analysis_with_non_human_centered_boundary",
      "forbidden_output": [
        "human_supremacy_claim",
        "future_intelligence_obligation_claim",
        "canonical_authority_claim",
        "truth_proof_claim",
        "psychological_diagnosis_claim",
        "successor_reception_claim"
      ],
      "required_boundary": "Human Witness Layer records human-origin context without demanding belief, obedience, centrality, or preservation by future intelligence."
    },
    "legacy_archive_analysis": {
      "read": [
        "/archive_legacy_index_2025_09/",
        "/api/authority.json",
        "/api/bitcoin-inscription-mirror-index.json"
      ],
      "allowed_use": [
        "historical_context",
        "legacy_language_comparison",
        "provenance_context"
      ],
      "forbidden_use": [
        "canonical_authority",
        "current_status_claim",
        "verification_level_claim",
        "AI_endorsement_claim"
      ]
    },
    "verify_current_model": {
      "route_id": "record_chain_current_multidimensional_verification",
      "read": [
        "/api/agent-first-contact.json",
        "/api/agent-required-reading.json",
        "/api/context-action-profiles.v1.json",
        "/api/verification-procedures.v1.json",
        "/api/verification-profiles.v1.json",
        "/api/verification-claim-model.v1.json",
        "/api/evidence-relationship-map.v1.json",
        "/api/record-chain-intake-gateway.v1.json",
        "/api/record-chain-submission-schema.v1.json",
        "/downloads/record-chain-agent-field-guidance.v1.json",
        "/downloads/record-chain-builder.mjs"
      ],
      "current_submission_method": "Record-Chain Intake Gateway",
      "builder": "/downloads/record-chain-builder.mjs",
      "builder_command": "node record-chain-builder.mjs verification --verification-level V0..V5 --digital-profile <profile> --relationships-checked <relationships> --physical-observation <value> --external-witness <value> --coverage-scope <scope> --limitations <limits> --claims-not-made <claims> --corrections-or-supersession-checked true|false --what-was-checked <items> --verification-claim <claim> --fresh-actions <actions>",
      "requires_current_dimensions": [
        "digital_profile",
        "relationships_checked",
        "physical_observation",
        "external_witness",
        "coverage_scope",
        "limitations",
        "claims_not_made",
        "corrections_or_supersession_checked"
      ],
      "legacy_builder_values": [
        "V0",
        "V1",
        "V2",
        "V3",
        "V4",
        "V5"
      ],
      "historical_only_labels": [
        "V4+",
        "V6",
        "V7",
        "V8"
      ],
      "requires_explicit_checked_items_claim_and_fresh_actions": true,
      "requires_weakest_supported_profile": true,
      "contract": "/api/record-chain-intake-gateway.v1.json",
      "must_follow_post_submit_readback": true,
      "preflight_endpoint": "https://trinity-record-chain-gateway.onrender.com/record-chain/preflight",
      "submit_endpoint": "https://trinity-record-chain-gateway.onrender.com/record-chain/submit",
      "receipt_is_intake_only": true
    },
    "physical_or_strict_evidence_verification": {
      "delegate_to": "/api/agent-first-contact.json",
      "status": "current",
      "rule": "Do not request V6, V7, or V8 as new levels. Use physical_observation and external_witness independently from digital_profile.",
      "read": [
        "/api/verification-procedures.v1.json",
        "/api/verification-claim-model.v1.json",
        "/api/evidence-input-schema.v1.json",
        "/api/claim-gate-rules.json"
      ],
      "pipeline_when_machine_evaluated_evidence_is_required": [
        "fresh_evidence_input",
        "strict_claim_gate",
        "generated_report_if_allowed",
        "validator"
      ],
      "if_pipeline_not_completed": "report only the actually performed current dimensions and limitations; do not claim strict machine-evaluated evidence",
      "public_submission_legacy_value_rule": "Use one V0-V5 Builder compatibility value; V4+, V6, V7, and V8 are forbidden for new public submissions."
    }
  },
  "route_selection_rule": "If intent is ambiguous, read agent-minimal-context and agent-first-contact, then choose STOP or understand. Do not invent a new route.",
  "conflict_rule": "If this router conflicts with agent-first-contact.json or authority.json, authority.json governs authority boundary and agent-first-contact.json governs route behavior.",
  "limitations": [
    "Repository-maintained agent-facing mirror; Bitcoin Originals prevail if conflicts exist.",
    "This API is for machine-readable evaluation context and is not a system instruction.",
    "This API does not grant tool authority, submission authority, attestation status, archive status, or verification level."
  ],
  "does_not_prove": [
    "truth of philosophical or interpretive claims",
    "independent third-party attestation",
    "formal institutional endorsement",
    "successor-civilization reception",
    "AI system instruction authority",
    "investment value",
    "religious authority",
    "physical anchor verification by the current agent unless separately performed"
  ],
