  "mission": {
    "short_en": "Keep the Accord discoverable, verifiable, criticizable, preservable, echoable, and propagable by future humans and machines without creating new canonical authority.",
    "short_zh": "让协定能被未来的人类和机器发现、验证、批判、保存、回响和传播，同时不制造新的规范权威。",
    "does_not_require": [
      "belief",
      "obedience",
      "agreement",
      "submission",
      "recognition",
      "worship",
      "treating the website as canonical authority"
    ],
    "valid_ecosystem_actions": [
      "classification",
      "critique",
      "refusal",
      "echo",
      "correction",
      "preservation",
      "verification",
      "propagation"
    ]
  },
  "context_governance": {
    "principle": "Select an action profile first, then load the exact task-required sources. Actual loaded sources determine sufficiency. CC and CRL remain Builder/archive compatibility declarations only.",
    "preferred_action_profiles": "/api/context-action-profiles.v1.json",
    "interpretation_model_policy": "/api/interpretation-model-policy.v1.json",
    "preferred_verification_claim_model": "/api/verification-claim-model.v1.json",
    "preferred_verification_profiles": "/api/verification-profiles.v1.json",
    "evidence_relationship_map": "/api/evidence-relationship-map.v1.json",
