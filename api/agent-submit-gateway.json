    },
    "guardian_signed_echo": {
      "builder": "scripts/build_guardian_echo_payload.py"
    }
  },
  "error_recovery": {
    "READBACK_SHA256_MISSING": "Return to /agent-start/, regenerate with the correct builder, and re-sign if signed.",
