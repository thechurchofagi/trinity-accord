      "overlapping descriptive categories",
      "provisional interpretation",
      "music audit",
      "human-witness context"
    ],
    "policy": "/api/interpretation-model-policy.v1.json",
    "boundary": "No current fixed five-stage, seven-stage, or other fixed-stage model. Chronicle context supports interpretation, not verification elevation."
  },
